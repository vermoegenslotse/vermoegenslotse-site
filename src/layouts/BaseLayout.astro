---
type Props = {
  title?: string;
};

const { title = "Vermögenslotse" } = Astro.props;

const path = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/tokens.css" />
  </head>

  <body>
    <header class="siteHeader">
      <div class="container headerInner">
        <div class="logo">
  <a href="/" class="logoLink" aria-label="Vermögenslotse – Start">
    <img src="/images/vermoegenslotse-logo.png" alt="Vermögenslotse" class="logoImg" />
  </a>
</div>

<nav class="site-nav" aria-label="Hauptnavigation">
  <a class={isActive("/") ? "active" : ""} href="/">Start</a>
  <a class={isActive("/ueber-mich") ? "active" : ""} href="/ueber-mich">Über mich</a>
  <a class={isActive("/so-arbeite-ich") ? "active" : ""} href="/so-arbeite-ich">So arbeite ich</a>
  <a class={isActive("/vermoegenscheck") ? "active" : ""} href="/vermoegenscheck">Vermögenscheck</a>
</nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="siteFooter">
      <div class="container footerInner">
        <div>
          © {new Date().getFullYear()} Vermögenslotse
        </div>
        <div class="footerLinks">
  <a href="/recht/impressum">Impressum</a>
  <a href="/recht/datenschutz">Datenschutz</a>
  <a href="/recht/transparenz">Transparenz</a>
  <a href="/recht/nachhaltigkeit">Nachhaltigkeit</a>
  <a href="/recht/erstinformation">Erstinformation</a>
</div>
      </div>
    </footer>
  </body>
</html>
