---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Ruhestands-Navigator | Vermögenslotse">
  <meta
    name="description"
    content="Berechnen Sie Ihre Versorgungslücke, Ihren Kapitalbedarf und den möglichen Handlungsbedarf für den Ruhestand – als erste Orientierung für eine strukturierte Ruhestandsplanung."
  />

  <section class="hero reveal">
    <div class="heroGrid retirementHeroGrid">
      <div>
        <div class="kicker">Ruhestandsplanung + Vermögensarchitektur</div>

        <h1 class="heroTitle">
          Ruhestands‑Navigator<br />
          <span class="heroTitleSub">Wie tragfähig ist Ihre Vermögensstruktur für den Ruhestand?</span>
        </h1>

        <p class="lead">
          Berechnen Sie Ihre Versorgungslücke, Ihren Kapitalbedarf und den möglichen
          Handlungsbedarf – als erste Orientierung, nicht als Produktrechner.
        </p>

        <p class="heroExplanation">
          Viele Vermögen sind aufgebaut, aber nicht auf die Entnahmephase vorbereitet.
          Entscheidend ist nicht nur die Rendite, sondern ob Struktur, Kapital und Zeitachse
          im Ruhestand zusammenpassen.
        </p>

        <div class="navigatorHighlights">
          <div class="navigatorHighlight panel">
            <h3>Versorgungslücke sichtbar machen</h3>
            <p class="muted">
              Der Rechner zeigt, welche monatliche Lücke heute und zum Ruhestandsbeginn
              unter den gewählten Annahmen entstehen kann.
            </p>
          </div>

          <div class="navigatorHighlight panel">
            <h3>Zielkapital einordnen</h3>
            <p class="muted">
              Sie erhalten eine erste Abschätzung, welches Kapital rechnerisch erforderlich
              wäre, um diese Lücke zu tragen.
            </p>
          </div>

          <div class="navigatorHighlight panel">
            <h3>Handlungsbedarf ableiten</h3>
            <p class="muted">
              Aus vorhandenem Vermögen und Zeit bis zum Ruhestand ergibt sich ein monatlicher
              Orientierungswert für den weiteren Vermögensaufbau.
            </p>
          </div>
        </div>
      </div>

      <div>
        <div class="retirementHeroVisual mediaCard mediaCard--soft">
          <img
            src="/images/ihr-vermoegen-in-sicheren-bahnen.png"
            alt="Ihr Vermögen in sicheren Bahnen – systematisch zu Ihrem Anlageziel"
            loading="eager"
          />
        </div>

        <aside class="panel retirementInfoPanel">
          <h2 class="sectionTitle">Worum es hier geht</h2>

          <ul class="bullets">
            <li>Inflation verändert Kaufkraft oft stärker als erwartet.</li>
            <li>Eine Versorgungslücke ist nicht nur eine Renditefrage, sondern vor allem eine Strukturfrage.</li>
            <li>Die Qualität der Entnahmestrategie entscheidet mit darüber, wie lange Vermögen trägt.</li>
          </ul>

          <p class="muted" style="margin-top:12px;">
            Dieser Rechner ist bewusst einfach gehalten und dient der ersten Einordnung.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <section class="section reveal">
    <h2 class="sectionTitle">Ihre Eingaben</h2>
    <p class="lead">
      Geben Sie Ihre Eckdaten ein. Die Berechnung läuft vollständig clientseitig in Ihrem Browser.
    </p>

    <div class="retirementLayout">
      <div class="retirementFormColumn">
        <div class="retirementGroup panel">
          <h3>Ihre Eckdaten</h3>
          <div class="retirementFieldGrid retirementFieldGrid2">
            <label class="retirementField">
              <span>Aktuelles Alter</span>
              <div class="retirementRangeTop">
                <span class="subtleText">Jahre</span>
                <strong data-range-output="currentAge">45</strong>
              </div>
              <input id="currentAge" type="range" min="18" max="75" step="1" value="45" />
            </label>

            <label class="retirementField">
              <span>Gewünschtes Ruhestandsalter</span>
              <div class="retirementRangeTop">
                <span class="subtleText">Jahre</span>
                <strong data-range-output="retirementAge">67</strong>
              </div>
              <input id="retirementAge" type="range" min="50" max="80" step="1" value="67" />
            </label>
          </div>

          <div class="retirementFieldGrid">
            <label class="retirementField">
              <span>Angenommene Lebenserwartung</span>
              <div class="retirementRangeTop">
                <span class="subtleText">Jahre</span>
                <strong data-range-output="lifeExpectancy">90</strong>
              </div>
              <input id="lifeExpectancy" type="range" min="70" max="105" step="1" value="90" />
            </label>
          </div>
        </div>

        <div class="retirementGroup panel">
          <h3>Ihr Einkommensziel im Ruhestand</h3>
          <div class="retirementFieldGrid">
            <label class="retirementField">
              <span>Gewünschte monatliche Ausgaben im Ruhestand</span>
              <input id="desiredIncome" type="number" min="0" step="100" value="4500" inputmode="decimal" />
            </label>
          </div>

          <div class="retirementFieldGrid retirementFieldGrid2">
            <label class="retirementField">
              <span>Erwartete gesetzliche Rente pro Monat</span>
              <input id="statePension" type="number" min="0" step="50" value="1800" inputmode="decimal" />
            </label>

            <label class="retirementField">
              <span>Sonstige sichere Renteneinkünfte pro Monat</span>
              <input id="privatePension" type="number" min="0" step="50" value="500" inputmode="decimal" />
            </label>
          </div>
        </div>

        <div class="retirementGroup panel">
          <h3>Ihr vorhandenes Vermögen</h3>
          <div class="retirementFieldGrid">
            <label class="retirementField">
              <span>Bereits vorhandenes Kapital</span>
              <input id="currentSavings" type="number" min="0" step="1000" value="150000" inputmode="decimal" />
            </label>
          </div>
        </div>

        <div class="retirementGroup panel">
          <h3>Annahmen für die Modellrechnung</h3>
          <div class="retirementFieldGrid retirementFieldGrid2">
            <label class="retirementField">
              <span>Inflation p. a.</span>
              <div class="retirementRangeTop">
                <span class="subtleText">in %</span>
                <strong data-range-output="inflationRate">2.0 %</strong>
              </div>
              <input id="inflationRate" type="range" min="0" max="6" step="0.1" value="2" />
            </label>

            <label class="retirementField">
              <span>Rentenanpassung p. a.</span>
              <div class="retirementRangeTop">
                <span class="subtleText">in %</span>
                <strong data-range-output="pensionIncrease">1.5 %</strong>
              </div>
              <input id="pensionIncrease" type="range" min="0" max="5" step="0.1" value="1.5" />
            </label>
          </div>

          <div class="retirementFieldGrid retirementFieldGrid2">
            <label class="retirementField">
              <span>Erwartete durchschnittliche Rendite p. a.</span>
              <div class="retirementRangeTop">
                <span class="subtleText">in %</span>
                <strong data-range-output="expectedReturn">5.0 %</strong>
              </div>
              <input id="expectedReturn" type="range" min="0" max="10" step="0.1" value="5" />
            </label>

            <label class="retirementField">
              <span>Steuerbelastung auf Kapitalerträge</span>
              <div class="retirementRangeTop">
                <span class="subtleText">in %</span>
                <strong data-range-output="taxRate">26.38 %</strong>
              </div>
              <input id="taxRate" type="range" min="0" max="35" step="0.01" value="26.38" />
            </label>
          </div>
        </div>
      </div>

      <div class="retirementResultsColumn">
        <div class="panel retirementResultsPanel">
          <h2 class="sectionTitle">Ihre Ruhestands‑Prognose</h2>

          <div class="retirementMetrics">
            <div class="retirementMetric card">
              <p class="subtleText">Versorgungslücke heute</p>
              <h3 id="metricGapToday">–</h3>
            </div>
            <div class="retirementMetric card">
              <p class="subtleText">Versorgungslücke zum Ruhestandsbeginn</p>
              <h3 id="metricGapRetirement">–</h3>
            </div>
            <div class="retirementMetric card">
              <p class="subtleText">Zielkapital zum Ruhestandsbeginn</p>
              <h3 id="metricRequiredCapital">–</h3>
            </div>
            <div class="retirementMetric card">
              <p class="subtleText">Zusätzlicher monatlicher Handlungsbedarf</p>
              <h3 id="metricMonthlyNeed">–</h3>
            </div>
          </div>

          <div class="retirementSummary card">
            <h3>Einordnung</h3>
            <p id="summaryText" class="muted"></p>
          </div>

          <div class="retirementWarning card">
            <h3>Was viele Anleger unterschätzen</h3>
            <ul class="bullets">
              <li>Inflation verändert die reale Kaufkraft stärker, als viele erwarten.</li>
              <li>Eine Versorgungslücke ist nicht nur eine Renditefrage, sondern vor allem eine Strukturfrage.</li>
              <li>Die Qualität der Entnahmestrategie entscheidet mit darüber, wie lange Vermögen trägt.</li>
            </ul>
          </div>

          <div class="retirementChart card">
            <h3>Versorgungslücke im Vergleich</h3>

            <div class="retirementBarRow">
              <div class="retirementBarHead">
                <span>Heute</span>
                <strong id="barLabelToday">–</strong>
              </div>
              <div class="retirementBarTrack">
                <div class="retirementBarFill" id="barToday"></div>
              </div>
            </div>

            <div class="retirementBarRow">
              <div class="retirementBarHead">
                <span>Zum Ruhestandsbeginn</span>
                <strong id="barLabelRetirement">–</strong>
              </div>
              <div class="retirementBarTrack">
                <div class="retirementBarFill" id="barRetirement"></div>
              </div>
            </div>

            <p class="muted" id="chartCaption"></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section sectionAlt reveal">
    <h2 class="sectionTitle">Was der Rechner zeigt – und was nicht</h2>

    <div class="cards">
      <div class="card">
        <h3>Was berechnet wird</h3>
        <p>
          Der Rechner zeigt, welche Versorgungslücke unter vereinfachten Annahmen im Ruhestand
          entstehen kann und welches Zielkapital dafür rechnerisch erforderlich wäre.
        </p>
      </div>
      <div class="card">
        <h3>Was nicht berücksichtigt wird</h3>
        <p>
          Nicht berücksichtigt werden u. a. individuelle Steuersituationen, Produktkosten,
          Erbschaften, Immobilienerträge oder besondere Entnahmestrategien.
        </p>
      </div>
      <div class="card">
        <h3>Warum das wichtig ist</h3>
        <p>
          Viele Depots wirken auf den ersten Blick solide. Entscheidend ist jedoch,
          ob sie im Ruhestand planbar tragen.
        </p>
      </div>
    </div>
  </section>

  <section class="section sectionAlt ctaProcess reveal">
    <div class="container">
      <h2 class="sectionTitle">Der nächste Schritt</h2>
      <p class="lead centerText">
        Wählen Sie das Gespräch, das zu Ihrer Situation passt.
      </p>

      <div class="bookingGrid">
        <div class="bookingCard">
          <div class="bookingHeader">
            <div class="bookingBadge">20 Minuten</div>
            <h3>Orientierungsgespräch</h3>
          </div>

          <p class="muted">
            Für alle, die das Ergebnis des Ruhestands‑Navigators einordnen und prüfen möchten,
            ob strategischer Handlungsbedarf besteht.
          </p>

          <ul class="bullets" style="margin-top:12px;">
            <li>Kurzer Überblick über Ihre Ausgangssituation</li>
            <li>Einordnung der Versorgungslücke und Zeitachse</li>
            <li>Nächster sinnvoller Schritt</li>
          </ul>

          <div class="btnRow" style="margin-top:16px;">
            <a class="btn" href="https://chgradt-gradt-consulting.zohobookings.eu/#/242656000000190002" target="_blank" rel="noopener">
              Orientierungsgespräch buchen
            </a>
          </div>

          <p class="subtleText" style="margin-top:10px;">
            Kostenlos & unverbindlich.
          </p>
        </div>

        <div class="bookingCard bookingCardAlt">
          <div class="bookingHeader">
            <div class="bookingBadge">60 Minuten</div>
            <h3>Strategiegespräch</h3>
          </div>

          <p class="muted">
            Für alle, die ihre Ruhestandsplanung, Vermögensstruktur und Entnahmephase konkreter
            besprechen möchten. Sinnvoll vor allem dann, wenn bereits Daten vorliegen.
          </p>

          <ul class="bullets" style="margin-top:12px;">
            <li>Struktur- & Risikoanalyse</li>
            <li>Einordnung der Versorgungslücke in die Vermögensarchitektur</li>
            <li>Prioritäten & nächste Schritte</li>
          </ul>

          <div class="btnRow" style="margin-top:16px;">
            <a class="btn btnSecondary" href="https://chgradt-gradt-consulting.zohobookings.eu/#/242656000000190020" target="_blank" rel="noopener">
              Strategiegespräch anfragen
            </a>
          </div>

          <p class="subtleText" style="margin-top:10px;">
            Hinweis: Die Terminbuchung ist erst nach Daten-Check sinnvoll.
          </p>
        </div>
      </div>

      <div class="centerText" style="margin-top:18px;">
        <a class="btn btnSecondary" href="/kontakt">Kontakt</a>
      </div>

      <p class="centerText subtleText" style="margin-top:12px;">
        Ich freue mich, Sie kennenzulernen.
      </p>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    const ids = [
      "currentAge",
      "retirementAge",
      "lifeExpectancy",
      "desiredIncome",
      "statePension",
      "privatePension",
      "currentSavings",
      "inflationRate",
      "pensionIncrease",
      "expectedReturn",
      "taxRate",
    ];

    const inputs = ids.map((id) => el(id)).filter(Boolean);

    function parseNum(value) {
      const num = Number(value);
      return Number.isFinite(num) ? num : 0;
    }

    function formatCurrency(value) {
      return new Intl.NumberFormat("de-DE", {
        style: "currency",
        currency: "EUR",
        maximumFractionDigits: 0,
      }).format(Math.max(0, value));
    }

    function formatPercent(value, digits = 1) {
      return `${Number(value).toFixed(digits).replace(".", ",")} %`;
    }

    function updateRangeOutputs() {
      document.querySelectorAll("[data-range-output]").forEach((node) => {
        const source = el(node.dataset.rangeOutput);
        if (!source) return;
        const value = parseNum(source.value);

        if (["inflationRate", "pensionIncrease", "expectedReturn"].includes(source.id)) {
          node.textContent = formatPercent(value, 1);
        } else if (source.id === "taxRate") {
          node.textContent = formatPercent(value, 2);
        } else {
          node.textContent = `${Math.round(value)}`;
        }
      });
    }

    function calculate() {
      updateRangeOutputs();

      const currentAge = parseNum(el("currentAge")?.value);
      const retirementAge = parseNum(el("retirementAge")?.value);
      const lifeExpectancy = parseNum(el("lifeExpectancy")?.value);
      const desiredIncome = parseNum(el("desiredIncome")?.value);
      const statePension = parseNum(el("statePension")?.value);
      const privatePension = parseNum(el("privatePension")?.value);
      const currentSavings = parseNum(el("currentSavings")?.value);
      const inflationRate = parseNum(el("inflationRate")?.value) / 100;
      const pensionIncrease = parseNum(el("pensionIncrease")?.value) / 100;
      const expectedReturn = parseNum(el("expectedReturn")?.value) / 100;
      const taxRate = parseNum(el("taxRate")?.value) / 100;

      const yearsToRetirement = Math.max(0, retirementAge - currentAge);
      const yearsInRetirement = Math.max(0, lifeExpectancy - retirementAge);
      const monthsToRetirement = yearsToRetirement * 12;
      const monthsInRetirement = yearsInRetirement * 12;

      const gapToday = Math.max(0, desiredIncome - statePension - privatePension);

      const futureDesiredIncome = desiredIncome * Math.pow(1 + inflationRate, yearsToRetirement);
      const futureStatePension = statePension * Math.pow(1 + pensionIncrease, yearsToRetirement);
      const futurePrivatePension = privatePension * Math.pow(1 + pensionIncrease, yearsToRetirement);
      const gapAtRetirement = Math.max(0, futureDesiredIncome - futureStatePension - futurePrivatePension);

      const netReturnAnnual = Math.max(0, expectedReturn * (1 - taxRate));
      const monthlyNetReturn = netReturnAnnual / 12;
      const monthlyGrossReturn = expectedReturn / 12;

      let requiredCapital = 0;
      if (monthsInRetirement > 0 && gapAtRetirement > 0) {
        if (monthlyNetReturn > 0) {
          requiredCapital = gapAtRetirement * ((1 - Math.pow(1 + monthlyNetReturn, -monthsInRetirement)) / monthlyNetReturn);
        } else {
          requiredCapital = gapAtRetirement * monthsInRetirement;
        }
      }

      let futureValueCurrentSavings = currentSavings;
      if (monthsToRetirement > 0 && currentSavings > 0 && monthlyGrossReturn > 0) {
        futureValueCurrentSavings = currentSavings * Math.pow(1 + monthlyGrossReturn, monthsToRetirement);
      }

      const additionalCapitalNeeded = Math.max(0, requiredCapital - futureValueCurrentSavings);

      let monthlySavingsRequired = 0;
      if (monthsToRetirement > 0 && additionalCapitalNeeded > 0) {
        if (monthlyGrossReturn > 0) {
          const annuityFactor = (Math.pow(1 + monthlyGrossReturn, monthsToRetirement) - 1) / monthlyGrossReturn;
          monthlySavingsRequired = annuityFactor > 0 ? additionalCapitalNeeded / annuityFactor : 0;
        } else {
          monthlySavingsRequired = additionalCapitalNeeded / monthsToRetirement;
        }
      }

      el("metricGapToday").textContent = formatCurrency(gapToday);
      el("metricGapRetirement").textContent = formatCurrency(gapAtRetirement);
      el("metricRequiredCapital").textContent = formatCurrency(requiredCapital);
      el("metricMonthlyNeed").textContent = formatCurrency(monthlySavingsRequired);

      const summary = yearsToRetirement === 0
        ? `Sie befinden sich rechnerisch bereits im Ruhestand. Unter den gewählten Annahmen ergibt sich aktuell eine monatliche Versorgungslücke von rund ${formatCurrency(gapAtRetirement)}. Um diese Lücke über etwa ${yearsInRetirement} Jahre auszugleichen, wäre ein Kapital von rund ${formatCurrency(requiredCapital)} erforderlich.`
        : `In voraussichtlich ${yearsToRetirement} Jahren beginnt Ihr Ruhestand. Unter den gewählten Annahmen entsteht dann eine monatliche Versorgungslücke von rund ${formatCurrency(gapAtRetirement)}. Um diese Lücke über einen Zeitraum von etwa ${yearsInRetirement} Jahren auszugleichen, wäre zum Ruhestandsbeginn ein Kapital von rund ${formatCurrency(requiredCapital)} erforderlich. Ausgehend von Ihrem heutigen Vermögen ergibt sich daraus ein zusätzlicher monatlicher Handlungsbedarf von rund ${formatCurrency(monthlySavingsRequired)}.`;

      el("summaryText").textContent = summary;

      const maxGap = Math.max(gapToday, gapAtRetirement, 1);
      const widthToday = Math.min(100, (gapToday / maxGap) * 100);
      const widthRet = Math.min(100, (gapAtRetirement / maxGap) * 100);

      el("barToday").style.width = `${widthToday}%`;
      el("barRetirement").style.width = `${widthRet}%`;
      el("barLabelToday").textContent = formatCurrency(gapToday);
      el("barLabelRetirement").textContent = formatCurrency(gapAtRetirement);
      el("chartCaption").textContent = "Die Vergleichsgrafik zeigt, wie sich die monatliche Versorgungslücke von heute bis zum Ruhestandsbeginn unter den gewählten Annahmen verändern kann.";
    }

    inputs.forEach((input) => {
      input.addEventListener("input", calculate);
      input.addEventListener("change", calculate);
    });

    calculate();
  </script>

  <style>
    .retirementHeroGrid {
      align-items: start;
      gap: 2rem;
    }

    .navigatorHighlights {
      display: grid;
      gap: 1rem;
      margin-top: 1.25rem;
    }

    .navigatorHighlight,
    .retirementGroup,
    .retirementResultsPanel,
    .retirementSummary,
    .retirementWarning,
    .retirementChart,
    .retirementMetric {
      background: rgba(255,255,255,0.72);
      border: 1px solid rgba(40,72,48,0.10);
      box-shadow: 0 10px 28px rgba(0,0,0,0.05);
    }

    .navigatorHighlight h3,
    .retirementGroup h3,
    .retirementSummary h3,
    .retirementWarning h3,
    .retirementChart h3,
    .retirementMetric h3 {
      margin-top: 0;
      color: var(--c-primary);
    }

    .retirementHeroVisual {
      margin-bottom: 1rem;
      padding: 0.6rem;
      border-radius: 22px;
      background: rgba(255,255,255,0.78);
      border: 1px solid rgba(40,72,48,0.10);
      box-shadow: 0 18px 44px rgba(0,0,0,0.06);
    }

    .retirementHeroVisual img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 18px;
    }

    .retirementInfoPanel {
      margin-top: 0;
    }

    .retirementLayout {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      gap: 1.5rem;
      align-items: start;
      margin-top: 1.5rem;
    }

    .retirementFormColumn,
    .retirementResultsColumn {
      display: grid;
      gap: 1rem;
    }

    .retirementGroup {
      display: grid;
      gap: 1rem;
    }

    .retirementFieldGrid {
      display: grid;
      gap: 1rem;
    }

    .retirementFieldGrid2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .retirementField {
      display: grid;
      gap: 0.5rem;
      font-weight: 600;
      color: var(--c-primary);
    }

    .retirementField span {
      color: var(--c-primary);
    }

    .retirementField input[type="number"] {
      width: 100%;
      padding: 0.95rem 1rem;
      border-radius: 14px;
      border: 1px solid rgba(40,72,48,0.14);
      background: rgba(255,255,255,0.92);
      color: var(--c-text);
      font: inherit;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.45);
    }

    .retirementField input[type="number"]:focus {
      outline: none;
      border-color: rgba(216,120,8,0.55);
      box-shadow: 0 0 0 4px rgba(216,120,8,0.12);
    }

    .retirementField input[type="range"] {
      width: 100%;
      accent-color: var(--c-accent);
    }

    .retirementRangeTop {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .retirementRangeTop strong {
      color: var(--c-accent);
      font-size: 0.98rem;
    }

    .retirementResultsPanel {
      display: grid;
      gap: 1rem;
      position: sticky;
      top: 96px;
    }

    .retirementMetrics {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .retirementMetric {
      min-height: 140px;
    }

    .retirementMetric p {
      margin-bottom: 0.5rem;
    }

    .retirementMetric h3 {
      font-size: clamp(1.25rem, 2.2vw, 1.85rem);
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 0;
    }

    .retirementBarRow + .retirementBarRow {
      margin-top: 1rem;
    }

    .retirementBarHead {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.4rem;
      color: var(--c-primary);
    }

    .retirementBarTrack {
      width: 100%;
      height: 12px;
      border-radius: 999px;
      background: rgba(40,72,48,0.08);
      overflow: hidden;
    }

    .retirementBarFill {
      height: 100%;
